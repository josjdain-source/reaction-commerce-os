# Reaction Commerce OS — 환경변수 예시 (.env.example)
# 실제 .env 는 .gitignore 로 제외됨. 이 파일에는 절대 진짜 키를 넣지 마세요.
# 복사:  cp .env.example .env   →  .env 에만 실제 값 입력

# --- 쿠팡 파트너스 Open API (대시보드 > API 발급) ---
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_PARTNER_ID=
COUPANG_TRACKING_CODE=
COUPANG_SUB_ID=

# --- (참고) 다른 모듈 키도 .env 에만. 코드/공개 repo 저장 금지 ---
# IG_ACCESS_TOKEN=
# IG_USER_ID=
